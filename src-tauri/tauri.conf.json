{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kasaio",
  "version": "1.1.2",
  "identifier": "com.canmu.kasaio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kasaio",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src http://127.0.0.1:*"
    }
  },
  "bundle": {
    "externalBin": ["binaries/python-sidecar"],
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Mustafa Fatih Can",
    "copyright": "Copyright © 2026 Mustafa Fatih Can"
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERERTk5QzZFNzgxNTE5QTMKUldTakdSVjRicHpwM2FCV3B5YmlHNlFPT3hiNUdFdUQ4SGdKR1ViSUlUUThHMFY5Ti92QTRId3cK",
      "endpoints": [
        "https://github.com/ConquistadorCan/Kasaio/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
