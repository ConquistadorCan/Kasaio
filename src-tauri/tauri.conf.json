{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kasaio",
  "version": "1.0.1",
  "identifier": "com.canmu.kasaio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kasaio",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "binaries/python-sidecar"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Mustafa Fatih Can",
    "copyright": "Copyright © 2026 Mustafa Fatih Can"
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
